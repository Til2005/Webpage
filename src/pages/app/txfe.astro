---
import AppLayout from "../../layouts/AppLayout.astro";
import TXFE from "../../components/TXFE/TXFE.astro";
---

<AppLayout
  title="TXFE — Foto Editor"
  description="TXFE - Ein minimalistischer Foto-Editor"
>
  <Fragment slot="header-left">
    <a href="/" class="txfe-back-btn">
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
      <span class="hidden sm:inline" data-i18n="txfeBack">Zurück</span>
    </a>
    <span class="txfe-title">TXFE</span>
  </Fragment>
  <TXFE />
</AppLayout>

<!-- TXC Bilder Gallery Modal -->
<div id="txcGalleryModal" class="txc-gallery-modal hidden" role="dialog" aria-modal="true" aria-label="TXC Bilder">
  <div class="txc-gallery-backdrop"></div>
  <div class="txc-gallery-panel">
    <div class="txc-gallery-header">
      <h2 class="txc-gallery-title">TXC Bilder</h2>
      <button id="txcGalleryClose" class="txc-gallery-close-btn" aria-label="Schließen">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div id="txcGalleryContent" class="txc-gallery-content">
      <p class="txc-gallery-status">Lade Bilder…</p>
    </div>
  </div>
</div>

<script>
  document.body.classList.add('app-txfe');

  import { loadImagesFromCloud } from '../../scripts/txc/txnSync';
  import { stateManager } from '../../scripts/txfe/stateManager';

  const galleryBtns = document.querySelectorAll<HTMLButtonElement>('.txc-gallery-btn');
  const galleryModal = document.getElementById('txcGalleryModal') as HTMLElement | null;
  const galleryClose = document.getElementById('txcGalleryClose') as HTMLButtonElement | null;
  const galleryContent = document.getElementById('txcGalleryContent') as HTMLElement | null;

  function openGallery() {
    galleryModal?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    loadGallery();
  }

  function closeGallery() {
    galleryModal?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  async function loadImageIntoTXFE(url: string, name: string, itemEl: HTMLElement) {
    itemEl.classList.add('txc-gallery-item--loading');

    try {
      const res = await fetch(url);
      const blob = await res.blob();
      const file = new File([blob], name, { type: blob.type || 'image/png' });

      const reader = new FileReader();
      reader.onload = (e) => {
        const dataUrl = e.target?.result as string;
        const img = new Image();
        img.onload = () => {
          stateManager.addImage(file, dataUrl, img.naturalWidth, img.naturalHeight);
          closeGallery();
        };
        img.src = dataUrl;
      };
      reader.readAsDataURL(blob);
    } catch {
      itemEl.classList.remove('txc-gallery-item--loading');
    }
  }

  async function loadGallery() {
    if (!galleryContent) return;
    galleryContent.innerHTML = '<p class="txc-gallery-status">Lade Bilder…</p>';

    const images = await loadImagesFromCloud();

    if (images === null) {
      galleryContent.innerHTML = '<p class="txc-gallery-status">Nicht angemeldet — bitte zuerst in <a href="/app/txc" class="txc-gallery-link">TXC</a> einloggen.</p>';
      return;
    }

    if (images.length === 0) {
      galleryContent.innerHTML = '<p class="txc-gallery-status">Noch keine Bilder in TXC gespeichert.</p>';
      return;
    }

    const grid = document.createElement('div');
    grid.className = 'txc-gallery-grid';

    for (const img of images) {
      const item = document.createElement('button');
      item.className = 'txc-gallery-item';
      item.title = `${img.name} öffnen`;
      item.type = 'button';

      const thumb = document.createElement('img');
      thumb.src = img.url;
      thumb.alt = img.name;
      thumb.loading = 'lazy';

      const name = document.createElement('span');
      name.className = 'txc-gallery-item-name';
      name.textContent = img.name;

      item.appendChild(thumb);
      item.appendChild(name);

      item.addEventListener('click', () => loadImageIntoTXFE(img.url, img.name, item));

      grid.appendChild(item);
    }

    galleryContent.innerHTML = '';
    galleryContent.appendChild(grid);
  }

  galleryBtns.forEach(btn => btn.addEventListener('click', openGallery));
  galleryClose?.addEventListener('click', closeGallery);

  galleryModal?.addEventListener('click', (e) => {
    if (e.target === galleryModal || (e.target as HTMLElement).classList.contains('txc-gallery-backdrop')) {
      closeGallery();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !galleryModal?.classList.contains('hidden')) {
      closeGallery();
    }
  });
</script>

<style>
  /* Gallery Modal */
  .txc-gallery-modal {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .txc-gallery-modal.hidden {
    display: none;
  }

  .txc-gallery-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(2px);
  }

  .txc-gallery-panel {
    position: relative;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    width: min(90vw, 860px);
    max-height: 80vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .txc-gallery-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.125rem 1.5rem;
    border-bottom: 1px solid var(--color-border);
    flex-shrink: 0;
  }

  .txc-gallery-title {
    font-size: 0.9375rem;
    font-weight: 600;
  }

  .txc-gallery-close-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: transparent;
    color: var(--color-fg);
    cursor: pointer;
    border: none;
    transition: background 0.15s;
    flex-shrink: 0;
  }

  .txc-gallery-close-btn:hover {
    background: color-mix(in srgb, var(--color-fg) 10%, transparent);
  }

  .txc-gallery-content {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem;
    scrollbar-width: thin;
    scrollbar-color: var(--color-muted) transparent;
  }

  .txc-gallery-status {
    color: var(--color-muted);
    font-size: 0.875rem;
    text-align: center;
    padding: 2.5rem 0;
  }

  .txc-gallery-link {
    color: var(--color-fg);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .txc-gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0.875rem;
  }

  .txc-gallery-item {
    display: flex;
    flex-direction: column;
    border-radius: 0.5rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: transparent;
    text-align: left;
    padding: 0;
    cursor: pointer;
    transition: border-color 0.15s, transform 0.15s, opacity 0.15s;
  }

  .txc-gallery-item:hover {
    border-color: var(--color-fg);
    transform: scale(1.02);
  }

  .txc-gallery-item--loading {
    opacity: 0.5;
    cursor: wait;
    pointer-events: none;
  }

  .txc-gallery-item img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  .txc-gallery-item-name {
    padding: 0.375rem 0.5rem;
    font-size: 0.6875rem;
    color: var(--color-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
