---
import AppLayout from "../../layouts/AppLayout.astro";
import TXN from "../../components/TXN/TXN.astro";
---

<AppLayout
  title="TXN — Notes"
  description="TXN – Minimalistische Notizen-App"
>
  <Fragment slot="header-left">
    <a href="/" class="txfe-back-btn">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
      <span class="hidden sm:inline">Zurück</span>
    </a>
    <span class="txfe-title">TXN</span>
    <!-- Mobile sidebar toggle -->
    <button
      id="txnSidebarToggle"
      class="txn-sidebar-toggle md:hidden ml-2"
      aria-label="Seitenleiste öffnen"
      aria-expanded="false"
      aria-controls="txnSidebar"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </Fragment>

  <TXN />
</AppLayout>

<script>document.body.classList.add('app-txn');</script>
