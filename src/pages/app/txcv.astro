---
import AppLayout from "../../layouts/AppLayout.astro";
import TXCV from "../../components/TXCV/TXCV.astro";
---

<AppLayout
  title="TXCV — Konverter"
  description="TXCV – Datei-Konverter für Bilder und Daten"
>
  <Fragment slot="header-left">
    <a href="/" class="txfe-back-btn">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
      <span class="hidden sm:inline">Zurück</span>
    </a>
    <span class="txfe-title">TXCV</span>
  </Fragment>
  <TXCV />
</AppLayout>

<script>document.body.classList.add('app-txcv');</script>

<style>
  .txfe-back-btn {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    color: var(--color-muted);
    transition: color 0.15s;
    text-decoration: none;
  }
  .txfe-back-btn:hover { color: var(--color-fg); }
  .txfe-title {
    font-weight: 600;
    font-size: 0.9375rem;
    letter-spacing: -0.01em;
  }
</style>
