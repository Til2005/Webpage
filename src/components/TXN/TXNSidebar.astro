---
// TXN Sidebar — Vault header, search, file tree, selection bar
---

<!-- Mobile overlay -->
<div class="txn-sidebar-overlay" id="txnSidebarOverlay" aria-hidden="true"></div>

<aside class="txn-sidebar" id="txnSidebar" aria-label="Notizen-Seitenleiste">
  <!-- Header -->
  <div class="txn-sidebar-header">
    <div class="txn-vault-name">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
        <polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      <span>Meine Notizen</span>
    </div>
    <div class="txn-sidebar-btns">
      <button
        id="txnNewNote"
        class="txn-icon-btn"
        title="Neue Notiz"
        aria-label="Neue Notiz erstellen"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
      </button>
      <button
        id="txnNewFolder"
        class="txn-icon-btn"
        title="Neuer Ordner"
        aria-label="Neuen Ordner erstellen"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
          <line x1="12" y1="11" x2="12" y2="17"/>
          <line x1="9" y1="14" x2="15" y2="14"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Search -->
  <div class="txn-search-wrap">
    <label for="txnSearch" class="sr-only">Notizen durchsuchen</label>
    <div class="txn-search-inner">
      <svg class="txn-search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input
        id="txnSearch"
        type="search"
        class="txn-search-input"
        placeholder="Suchen…"
        autocomplete="off"
        spellcheck="false"
        aria-label="Notizen durchsuchen"
      >
    </div>
  </div>

  <!-- File tree -->
  <div class="txn-file-tree" id="txnFileTree" role="tree" aria-label="Notizen-Verzeichnis"></div>

  <!-- Search results (shown while searching) -->
  <div class="txn-search-results" id="txnSearchResults" style="display:none" role="list" aria-label="Suchergebnisse"></div>

  <!-- Selection bar (shown when notes are selected) -->
  <div class="txn-selection-bar" id="txnSelectionBar" style="display:none" role="toolbar" aria-label="Auswahl-Aktionen">
    <span id="txnSelectionCount" class="txn-selection-count"></span>
    <div class="txn-selection-actions">
      <button data-export-format="md" class="txn-icon-btn" title="Als Markdown exportieren" aria-label="Auswahl als Markdown exportieren">MD</button>
      <button data-export-format="txt" class="txn-icon-btn" title="Als Text exportieren" aria-label="Auswahl als Text exportieren">TXT</button>
      <button data-export-format="docx" class="txn-icon-btn" title="Als DOCX exportieren" aria-label="Auswahl als DOCX exportieren">DOCX</button>
      <button id="txnSelectionClear" class="txn-icon-btn" title="Auswahl aufheben" aria-label="Auswahl aufheben">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>
</aside>
