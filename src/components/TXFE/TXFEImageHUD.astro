---

<div class="txfe-image-hud">
  <div class="txfe-hud-container">
    <!-- Image thumbnails -->
    <div id="txfeImageHUD" class="txfe-hud-scroll">
      <!-- Thumbnails will be inserted here dynamically -->
    </div>

    <!-- Add image button (always visible, right side) -->
    <button id="txfeHudAdd" class="txfe-hud-add" aria-label="Bild hinzufügen">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="12" y1="5" x2="12" y2="19"></line>
        <line x1="5" y1="12" x2="19" y2="12"></line>
      </svg>
      <span>Bild hinzufügen</span>
    </button>
  </div>
</div>

<style>
  .txfe-image-hud {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 18vh;
    min-height: 140px;
    max-height: 200px;
    background-color: #F8F3F0;
    border-top: 1px solid var(--color-border);
    z-index: 40;
    display: none; /* Hidden by default, shown when images are added */
    align-items: center;
  }

  :global([data-theme="dark"]) .txfe-image-hud {
    background-color: #212124;
  }

  .txfe-hud-container {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
  }

  .txfe-hud-scroll {
    flex: 1;
    height: 100%;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    overflow-x: auto;
    overflow-y: visible;
    padding: 0.5rem 0.75rem;
    scrollbar-width: thin;
    scrollbar-color: var(--color-muted) transparent;
  }

  .txfe-hud-scroll::-webkit-scrollbar {
    height: 6px;
  }

  .txfe-hud-scroll::-webkit-scrollbar-track {
    background: transparent;
  }

  .txfe-hud-scroll::-webkit-scrollbar-thumb {
    background-color: var(--color-muted);
    border-radius: 3px;
  }

  .txfe-hud-scroll::-webkit-scrollbar-thumb:hover {
    background-color: var(--color-fg);
  }

  /* Image item */
  :global(.txfe-hud-item) {
    position: relative;
    height: 110px;
    width: 165px;
    flex-shrink: 0;
    border-radius: 0.5rem;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.2s ease;
    border: 2px solid transparent;
  }

  :global(.txfe-hud-item:hover) {
    transform: scale(1.05);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  :global(.txfe-hud-item.active) {
    border-color: var(--color-fg);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    transform: scale(1.08);
  }

  :global(.txfe-hud-item img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Remove button */
  :global(.txfe-hud-item-remove) {
    position: absolute;
    top: 0.25rem;
    right: 0.25rem;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.8);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
    cursor: pointer;
    z-index: 10;
  }

  [data-theme="dark"] :global(.txfe-hud-item-remove) {
    background: rgba(255, 255, 255, 0.9);
    color: black;
  }

  :global(.txfe-hud-item:hover .txfe-hud-item-remove) {
    opacity: 1;
  }

  :global(.txfe-hud-item-remove:hover) {
    transform: scale(1.15);
  }

  /* Image number badge */
  :global(.txfe-hud-item-number) {
    position: absolute;
    bottom: 0.25rem;
    left: 0.25rem;
    padding: 0.125rem 0.375rem;
    background: rgba(0, 0, 0, 0.75);
    color: white;
    font-size: 0.625rem;
    font-weight: 700;
    border-radius: 0.25rem;
    backdrop-filter: blur(4px);
  }

  [data-theme="dark"] :global(.txfe-hud-item-number) {
    background: rgba(255, 255, 255, 0.25);
  }


  /* Add image button */
  .txfe-hud-add {
    flex-shrink: 0;
    margin-left: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    height: 110px;
    width: 165px;
    border-radius: 0.5rem;
    border: 1px solid var(--color-fg);
    color: var(--color-fg);
    background-color: transparent;
    cursor: pointer;
    transition: background-color 0.2s, color 0.2s;
    font-size: 0.75rem;
    font-weight: 500;
    text-align: center;
    line-height: 1.3;
  }

  .txfe-hud-add:hover {
    background-color: #F0ECE9;
  }

  :global([data-theme="dark"]) .txfe-hud-add:hover {
    background-color: #1F1F21;
  }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    .txfe-image-hud {
      height: 18vh;
      min-height: 130px;
      max-height: 180px;
    }

    .txfe-hud-container {
      padding: 0.5rem 1rem;
      gap: 0.75rem;
    }

    .txfe-hud-scroll {
      gap: 0.5rem;
    }

    :global(.txfe-hud-item) {
      height: 90px;
      width: 135px;
    }

    .txfe-hud-add {
      height: 90px;
      width: 135px;
    }

  }
</style>
