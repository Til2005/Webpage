---

---

<div class="txfe-preview">
  <!-- Hidden file input -->
  <input
    type="file"
    id="txfeFileInput"
    accept="image/*"
    multiple
    class="hidden"
    aria-label="Upload images"
  />

  <!-- Main image container -->
  <div id="txfeImageContainer" class="txfe-image-container">
    <!-- Empty state (shown when no images) -->
    <div id="txfeEmptyState" class="txfe-empty-state">
      <svg
        class="txfe-empty-icon"
        width="64"
        height="64"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        aria-hidden="true"
      >
        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
        <circle cx="8.5" cy="8.5" r="1.5"></circle>
        <polyline points="21 15 16 10 5 21"></polyline>
      </svg>
      <p class="txfe-empty-text" data-i18n="txfeDropImages">Bilder hier ablegen</p>
      <p class="txfe-empty-subtext" data-i18n="txfeClickToSelect">oder klicken zum Auswählen</p>
    </div>

    <!-- Image preview (hidden by default) -->
    <img
      id="txfePreviewImage"
      class="txfe-preview-image hidden"
      alt="Preview"
    />

    <!-- Crop overlay (hidden by default) -->
    <div id="txfeCropOverlay" class="txfe-crop-overlay hidden">
      <div id="txfeCropFrame" class="txfe-crop-frame">
        <!-- Resize handles -->
        <div class="txfe-crop-handle txfe-crop-handle-nw" data-handle="nw" aria-label="Resize top-left"></div>
        <div class="txfe-crop-handle txfe-crop-handle-ne" data-handle="ne" aria-label="Resize top-right"></div>
        <div class="txfe-crop-handle txfe-crop-handle-sw" data-handle="sw" aria-label="Resize bottom-left"></div>
        <div class="txfe-crop-handle txfe-crop-handle-se" data-handle="se" aria-label="Resize bottom-right"></div>
      </div>
    </div>

    <!-- Text overlay (hidden by default) -->
    <div id="txfeTextOverlay" class="txfe-text-overlay hidden">
      <div id="txfeTextPreviewContent" class="txfe-text-content"></div>
    </div>
  </div>

  <!-- Drop overlay (shown during drag-over) -->
  <div id="txfeDropOverlay" class="txfe-drop-overlay hidden">
    <svg
      width="48"
      height="48"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      aria-hidden="true"
    >
      <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
      <polyline points="17 8 12 3 7 8"></polyline>
      <line x1="12" y1="3" x2="12" y2="15"></line>
    </svg>
    <p data-i18n="txfeDropImages">Bilder hier ablegen</p>
  </div>
</div>

<style>
  .txfe-preview {
    position: relative;
    width: 100%;
    max-width: 1000px;
    aspect-ratio: 16/10;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-bg);
    border: 2px dashed var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
    cursor: pointer;
    transition: border-color 0.2s ease, background-color 0.2s ease;
    margin: 0 auto;
  }

  .txfe-preview:hover {
    border-color: var(--color-fg);
    background-color: color-mix(in srgb, var(--color-fg) 4%, var(--color-bg));
  }

  /* Image container */
  .txfe-image-container {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Empty state */
  .txfe-empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: var(--color-muted);
    text-align: center;
    padding: 2rem;
  }

  .txfe-empty-icon {
    opacity: 0.5;
  }

  .txfe-empty-text {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-fg);
  }

  .txfe-empty-subtext {
    font-size: 0.875rem;
  }

  /* Preview image */
  .txfe-preview-image {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    max-width: 95%;
    max-height: 95%;
    width: auto;
    height: auto;
    object-fit: contain;
    pointer-events: none;
    user-select: none;
  }

  /* Crop overlay */
  .txfe-crop-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .txfe-crop-frame {
    position: absolute;
    border: 2px solid var(--color-fg);
    box-shadow: 0 0 0 9999px rgba(0, 0, 0, 0.5);
    cursor: move;
    pointer-events: auto;
    transition: none;
  }

  /* Crop handles */
  .txfe-crop-handle {
    position: absolute;
    width: 1.25rem;
    height: 1.25rem;
    background-color: var(--color-fg);
    border: 2px solid var(--color-bg);
    border-radius: 50%;
    pointer-events: auto;
    transition: transform 0.2s ease;
  }

  .txfe-crop-handle:hover {
    transform: scale(1.2);
  }

  .txfe-crop-handle-nw {
    top: -0.625rem;
    left: -0.625rem;
    cursor: nw-resize;
  }

  .txfe-crop-handle-ne {
    top: -0.625rem;
    right: -0.625rem;
    cursor: ne-resize;
  }

  .txfe-crop-handle-sw {
    bottom: -0.625rem;
    left: -0.625rem;
    cursor: sw-resize;
  }

  .txfe-crop-handle-se {
    bottom: -0.625rem;
    right: -0.625rem;
    cursor: se-resize;
  }

  /* Text overlay */
  .txfe-text-overlay {
    position: absolute;
    pointer-events: auto;
    cursor: move;
    user-select: none;
    padding: 0.5rem;
    transition: none;
  }

  .txfe-text-content {
    font-weight: 700;
    text-shadow:
      2px 2px 4px rgba(0, 0, 0, 0.8),
      -1px -1px 2px rgba(0, 0, 0, 0.5);
    white-space: nowrap;
  }

  /* Drop overlay */
  .txfe-drop-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    background-color: color-mix(in srgb, var(--color-fg) 10%, transparent);
    border: 3px dashed var(--color-fg);
    border-radius: 0.5rem;
    color: var(--color-fg);
    font-size: 1.125rem;
    font-weight: 600;
    pointer-events: none;
    z-index: 10;
  }

  /* Hidden utility */
  .hidden {
    display: none !important;
  }
</style>
