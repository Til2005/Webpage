---
import TXFEPreview from "./TXFEPreview.astro";
import TXFETabs from "./TXFETabs.astro";
import TXFEFilterTab from "./TXFEFilterTab.astro";
import TXFECropTab from "./TXFECropTab.astro";
import TXFEDesignTab from "./TXFEDesignTab.astro";
import TXFEImageHUD from "./TXFEImageHUD.astro";
---

<div class="txfe-app">
  <div class="txfe-main-content">
    <!-- Left side: Controls (desktop) -->
    <div class="txfe-sidebar hidden sm:flex flex-col">
      <!-- Tabs and Panels -->
      <div class="txfe-controls flex-1 flex flex-col overflow-hidden">
        <div class="px-6 pt-6 pb-4">
          <div class="flex gap-2 items-center">
            <TXFETabs />
            <button class="txc-gallery-btn txfe-action-btn ml-auto" type="button" style="flex-shrink:0" aria-label="TXC Bilder anzeigen">
              TXC Bilder
            </button>
          </div>
        </div>
        <div class="txfe-panels flex-1 overflow-y-auto px-6 py-6">
          <TXFEFilterTab />
          <TXFECropTab />
          <TXFEDesignTab />
        </div>
      </div>
    </div>

    <!-- Preview -->
    <div class="txfe-preview-area">
      <TXFEPreview />
    </div>
  </div>

  <!-- Mobile: Controls -->
  <div class="txfe-mobile-controls sm:hidden">
    <div class="px-4 pt-4 pb-3">
      <div class="flex gap-2 items-center">
        <TXFETabs />
        <button class="txc-gallery-btn txfe-action-btn ml-auto" type="button" style="flex-shrink:0" aria-label="TXC Bilder anzeigen">
          TXC Bilder
        </button>
      </div>
    </div>
    <div class="txfe-panels-mobile overflow-y-auto p-4" style="max-height: 180px;">
      <TXFEFilterTab />
      <TXFECropTab />
      <TXFEDesignTab />
    </div>
  </div>
</div>

<!-- Image HUD (bottom, always visible) -->
<TXFEImageHUD />


<script>
  import { initTXFE } from "../../scripts/txfe/main";
  initTXFE();
</script>

<style>
  .txfe-app {
    background-color: var(--color-bg);
    height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .txfe-main-content {
    flex: 1;
    display: flex;
    overflow: hidden;
    padding-bottom: 18vh; /* Space for HUD */
    min-height: 0;
  }

  @media (max-width: 640px) {
    .txfe-main-content {
      padding-bottom: 18vh; /* Space for HUD on mobile */
    }
  }

  .txfe-sidebar {
    width: 500px;
    min-width: 500px;
    max-width: 500px;
    background-color: #F8F3F0;
    border-right: 1px solid var(--color-border);
    margin-bottom: -18vh;
    padding-bottom: 18vh;
  }
  :global([data-theme="dark"]) .txfe-sidebar {
    background-color: #212124;
  }

  @media (min-width: 1280px) {
    .txfe-sidebar {
      width: 560px;
      min-width: 560px;
      max-width: 560px;
    }
  }

  .txfe-controls {
    background-color: #F8F3F0;
  }
  :global([data-theme="dark"]) .txfe-controls {
    background-color: #212124;
  }

  .txfe-panels {
    scrollbar-width: none;
  }
  .txfe-panels::-webkit-scrollbar {
    display: none;
  }

  .txfe-preview-area {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 1.25rem 3.8rem;
    overflow: auto;
  }

  @media (max-width: 640px) {
    .txfe-preview-area {
      padding: 1rem;
    }
  }

  .txfe-mobile-controls {
    background-color: #F8F3F0;
    border-top: 1px solid var(--color-border);
    padding-bottom: 18vh; /* Space for HUD */
  }
  :global([data-theme="dark"]) .txfe-mobile-controls {
    background-color: #212124;
  }

  /* Add more button styled like a tab */
  :global(.txfe-tab-add) {
    padding: 0.625rem 1.25rem;
    font-size: 0.9375rem;
    font-weight: 500;
    border-radius: 9999px;
    color: var(--color-muted);
    background-color: transparent;
    transition: background-color 0.2s, color 0.2s;
    white-space: nowrap;
  }

  :global(.txfe-tab-add:hover) {
    background-color: color-mix(in srgb, var(--color-fg) 8%, transparent);
    color: var(--color-fg);
  }

  :global(.txfe-tab-add:focus-visible) {
    outline: 2px solid var(--color-fg);
    outline-offset: 2px;
  }

  :global(.txfe-tab-add.hidden) {
    display: none;
  }
</style>
